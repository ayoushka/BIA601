{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/users",
      "destination": "/backend/main.py"
    },
    {
      "source": "/recommend/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/generation/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/mutate/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}
